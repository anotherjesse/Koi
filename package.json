{
  "name": "koifarm",
  "version": "1.1.0",
  "author": "Job Talle",
  "description": "A browser-first Koi breeding game and embeddable web component",
  "type": "module",
  "main": "embed/koi-farm.js",
  "module": "embed/koi-farm.js",
  "exports": {
    ".": "./embed/koi-farm.js",
    "./embed": "./embed/koi-farm.js",
    "./world": "./embed/koi-farm.js",
    "./system": "./embed/koi-farm.js",
    "./package.json": "./package.json"
  },
  "files": [
    "audio",
    "css",
    "embed",
    "font",
    "js",
    "KoiTranslations",
    "svg",
    "autumn.css",
    "favicon.ico",
    "index.html",
    "manifest.json",
    "screenshots.png",
    "winter.css",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/serve.mjs",
    "preview": "node scripts/serve.mjs --root dist",
    "start": "npm run dev",
    "test": "node --test"
  }
}
